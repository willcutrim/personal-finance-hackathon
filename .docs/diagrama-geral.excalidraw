      "type": "text",
      "x": 1545.382765076301,
      "y": 4766.8243487435375,
      "width": 441.6168212890625,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
